# Example local developer configuration.
# Copy to .env.local and edit for your machine. Do not commit .env.local.
# Values below are examples, not necessarily the active local defaults.

# Frontend runtime config generated into:
# frontend/apps/transformation-console/public/assets/runtime-config.js
# Use mock + true for frontend-only work.
# Use http://localhost:5029 + false when running the .NET API locally.
LAR_FRONTEND_API_BASE_URL=http://localhost:5029
LAR_FRONTEND_MOCK_API=false
LAR_FRONTEND_PORT=4300

# Backend local defaults. .NET can read these environment variables directly.
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5001
ConnectionStrings__ModernisationDb=Data Source=local-example.db

# Docker Compose defaults can also use this file via:
# docker compose --env-file .env.local up --build
LAR_BACKEND_CONTAINER_URLS=http://+:8080
LAR_BACKEND_PORT=5001
