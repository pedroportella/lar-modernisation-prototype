{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "baseUrl": ".",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@lar/services": ["libs/services/src/index.ts"],
      "@lar/mock-api-fixtures": ["libs/services/src/lib/mock-api.fixtures.ts"],
      "@lar/ui-assets": ["libs/ui-assets/src/index.ts"],
      "@lar/ui-library": ["libs/ui-library/src/index.ts"],
      "@lar/utils": ["libs/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
