{
  "name": "lar-modernisation-prototype",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "frontend:dev": "pnpm --dir frontend exec nx serve transformation-console",
    "frontend:build": "pnpm --dir frontend exec nx build transformation-console",
    "frontend:lint": "pnpm --dir frontend exec nx lint transformation-console",
    "frontend:format": "pnpm --dir frontend exec prettier . --write",
    "frontend:format:check": "pnpm --dir frontend exec prettier . --check",
    "frontend:typecheck": "pnpm --dir frontend exec tsc -p apps/transformation-console/tsconfig.app.json --noEmit",
    "frontend:e2e": "pnpm --dir frontend exec nx e2e transformation-console-e2e",
    "backend:dev": "dotnet run --project backend/src/LargeRetailer.Modernisation.Api",
    "backend:build": "dotnet build backend/LargeRetailer.Modernisation.sln",
    "backend:format": "dotnet format whitespace backend/LargeRetailer.Modernisation.sln --no-restore",
    "backend:format:check": "dotnet format whitespace backend/LargeRetailer.Modernisation.sln --no-restore --verify-no-changes",
    "backend:test": "dotnet test backend/LargeRetailer.Modernisation.sln --no-restore /nr:false /m:1",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "format": "pnpm frontend:format && pnpm backend:format",
    "format:check": "pnpm frontend:format:check && pnpm backend:format:check",
    "verify": "pnpm format:check && pnpm frontend:lint && pnpm frontend:typecheck && pnpm backend:test",
    "verify:full": "pnpm verify && pnpm docker:build"
  },
  "packageManager": "pnpm@10.18.3+sha512.bbd16e6d7286fd7e01f6b3c0b3c932cda2965c06a908328f74663f10a9aea51f1129eea615134bf992831b009eabe167ecb7008b597f40ff9bc75946aadfb08d"
}
